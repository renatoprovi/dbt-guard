{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch dbt-guard",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/dbt-guard",
      "args": ["${workspaceFolder}/examples"]
    },
    {
      "name": "Launch current file",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${file}"
    },
    {
      "name": "Debug tests (current file)",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}",
      "args": ["-test.run", "^${selectedText}$"]
    },
    {
      "name": "Debug tests (package)",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${fileDirname}"
    }
  ]
}
